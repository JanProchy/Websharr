# All of this is optional — the first-run wizard at http://localhost:9797/ui
# sets up the Webshare account and generates an API key for you.
# Values saved in the UI (persisted to /config/settings.json) override these.
WEBSHARE_USERNAME=
WEBSHARE_PASSWORD=
#WEBSHARR_API_KEY=
# TMDB API Read Access Token (v4 bearer) for Czech-title lookups; also settable in the UI.
#TMDB_TOKEN=

# The user the container runs as — set to your host UID/GID (`id -u` / `id -g`)
# so downloaded files belong to you. Defaults to 1000:1000.
#PUID=1000
#PGID=1000
